#!/bin/bash -eux

VB_VERSION=$(VBoxManage -V | cut -d. -f1)
MA4_VERSION="@MA4_VERSION@"

ARCHITECTURE=$(uname -m)
if [ ${ARCHITECTURE} = x86_64 ]; then
  ARCHITECTURE=amd64
fi

if [ -f ma4-${ARCHITECTURE}.json ]; then
  rm -rf output-virtualbox-iso
  packer build ma4-${ARCHITECTURE}.json 2>&1 | tee build-ma4-${ARCHITECTURE}.log
  if [ -f output-virtualbox-iso/MateriAppsLive-${MA4_VERSION}-${ARCHITECTURE}.ova ]; then
    mv -f output-virtualbox-iso/MateriAppsLive-${MA4_VERSION}-${ARCHITECTURE}.ova .
  else
    echo "Error: build failed."
    exit 127
  fi
fi
d
