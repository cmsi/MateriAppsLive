#!/bin/bash -eux

VB_VERSION=$(VBoxManage -V | cut -d. -f1)
CE4_VERSION="@CE4_VERSION@"

ARCHITECTURE=$(uname -m)
if [ ${ARCHITECTURE} = x86_64 ]; then
  ARCHITECTURE=amd64
fi

if [ -f ce4-${ARCHITECTURE}.json ]; then
  rm -rf output-virtualbox-iso
  packer build ce4-${ARCHITECTURE}.json 2>&1 | tee build-ce4-${ARCHITECTURE}.log
  if [ -f output-virtualbox-iso/ceenv-${CE4_VERSION}-${ARCHITECTURE}.ova ]; then
    mv -f output-virtualbox-iso/ceenv-${CE4_VERSION}-${ARCHITECTURE}.ova .
  else
    echo "Error: build failed."
    exit 127
  fi
fi
